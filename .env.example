# Optional: explicitly set your GCP project ID
GOOGLE_CLOUD_PROJECT=

# Preferred: service account key path (can be relative to project root)
FIREBASE_SERVICE_ACCOUNT=serviceAccountKey.json

# Optional: set a different user id default for frontend
DEFAULT_USER_ID=girlfriend

# Required if running locally with service account json
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account.json
